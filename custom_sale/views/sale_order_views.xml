<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_inherit_logistiques" model="ir.ui.view">
        <field name="name">sale.order.form.logistiques</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Logistics Info">
                    <group>
                        <field name="notes_logistiques" widget="html" options="{'toolbar': 'full'}"/>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
